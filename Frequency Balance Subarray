You are given an integer array ‚Äã‚Äã‚Äã‚Äã‚Äã‚Äã‚Äãnums.
Define a frequency balance subarray as follows:
If the subarray contains only one distinct value, it is frequency balanced.
Otherwise, there must exist a positive integer f such that every distinct value in the subarray occurs either f or 2 * f times,
and both frequencies occur among the distinct values.
Return an integer denoting the length of the longest frequency balance subarray.

Example 1:
Input: nums = [1,2,2,1,2,3,3,3]
Output: 5
Explanation:
The longest frequency balance subarray is [2, 1, 2, 3, 3].
The elements that appear most frequently are 2 and 3, both appearing twice.
The remaining element 1 appears once, meeting the requirements.

Example 2:
Input: nums = [5,5,5,5]
Output: 4
Explanation:
The longest frequency balance subarray is [5, 5, 5, 5].
The element that appears most frequently is 5.
There are no other elements meeting the requirements.



-----------------------------------SOLUTION---------------------------------------

/**
 * @param {number[]} nums
 * @return {number}
 */
var getLength = function(nums) {
      const n = nums.length;
    let ans = 1;

    for (let i = 0; i < n; i++) {

        const freq = new Map();
        const freqCount = new Map();

        let maxFreq = 0;

        for (let j = i; j < n; j++) {

            const x = nums[j];

            const oldFreq = freq.get(x) || 0;

            // remove old frequency
            if (oldFreq > 0) {
                let cnt = freqCount.get(oldFreq) - 1;

                if (cnt === 0)
                    freqCount.delete(oldFreq);
                else
                    freqCount.set(oldFreq, cnt);
            }

            // add new frequency
            const newFreq = oldFreq + 1;
            freq.set(x, newFreq);

            freqCount.set(
                newFreq,
                (freqCount.get(newFreq) || 0) + 1
            );

            maxFreq = Math.max(maxFreq, newFreq);

            const distinct = freq.size;

            if (distinct === 1) {
                ans = Math.max(ans, j - i + 1);
            }
            else if (
                maxFreq % 2 === 0 &&
                freqCount.size === 2 &&
                freqCount.has(maxFreq) &&
                freqCount.has(maxFreq / 2)
            ) {
                ans = Math.max(ans, j - i + 1);
            }
        }
    }

    return ans;
};
